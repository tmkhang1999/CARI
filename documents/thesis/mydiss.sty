% definition of a new aspect
\newcommand{\defi}[1]{\emph{#1}}

% definition + index command
\newcommand{\defix}[2][]{\defi{#2}\ifthenelse{\equal{#1}{}}{\index{#2}}{\index{#1}}}
\newcommand{\defixaam}[2][]{\defi{#2}\ifthenelse{\equal{#1}{}}{\index{Active Appearance Model!#2}}{\index{Active Appearance Model!#1}}}

