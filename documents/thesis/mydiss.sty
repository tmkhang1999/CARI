% \tightmtcfalse
% \dominitoc[c]

% numbered subsubsections (see "tocdepth" for depth of table of contents)
\setcounter{secnumdepth}{3}

% needed to change style of headings
\usepackage{titlesec}

% chapter
\titleformat{\chapter}[hang]{\color{myprimary}\Huge\bfseries}{\thechapter\hspace{5mm}\textcolor{mysecondary}{\mvrb}\hspace{5mm}}{0pt}{\Huge\bfseries}

% section
\titleformat{\section}[hang]
{\color{myprimary}\normalfont\LARGE\bfseries}
{\thesection}{1ex}{}[]

% subsection
\titleformat{\subsection}[hang]
{\color{myprimary}\normalfont\Large\bfseries}
{\thesubsection}{1ex}{}[]

% subsubsection
\titleformat{\subsubsection}[hang]
{\color{myprimary}\normalfont\large\bfseries}
{\thesubsubsection}{1ex}{}[]

% paragraph
\titleformat{\paragraph}[runin]
{\color{myprimary}\normalfont\bfseries}
{}{0ex}{}[.]

