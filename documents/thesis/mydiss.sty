% header line
%-------------------------------------------------------------------------------

% inspired by http://www.kfiles.de/latex.php

% inspired by warning message "Package Fancyhdr Warning: \headheight is too small (12.0pt)"
\setlength{\headheight}{25.1pt}

% necessary package
\usepackage{fancyhdr}
\pagestyle{fancy}

% format chapter title used in header
\renewcommand{\chaptermark}[1]{%
   \markboth{%
      \ifnum \c@secnumdepth >\m@ne
         \if@mainmatter
            \textbf{\@chapapp\ \thechapter}\hspace{2ex}\mvr\hspace{2ex}%
         \fi
      \fi
      \MakeUppercase{#1}
   }{}%
}

% format section title used in header
\renewcommand{\sectionmark}[1]{%
   \markright{%
      #1%
      \ifnum \c@secnumdepth >\z@
         \hspace{2ex}\mvr\hspace{2ex}\textsf{\textbf{\thesection}}%
      \fi
   }%
}

% clear header/footer settings
\fancyhead{}
\fancyfoot{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

% chapter and section title in head
\fancyhead[EL]{\small\textsf{\leftmark}}
\fancyhead[OR]{\small\textsf{\rightmark}}

% page numbers in foot
\fancyfoot[EL,OR]{\textsf{\thepage}}

% also change font for chapter title pages
\fancypagestyle{plain}{%
\fancyhf{}%
\fancyfoot[C]{\textsf{\thepage}}%
}

