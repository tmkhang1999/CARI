% show pages of citations in bibliography
\usepackage{backref}
\renewcommand*{\backref}[1]{}%
\renewcommand*{\backrefalt}[4]{%
   \ifnum#1=0 %
      % print nothing if no reference
   \else
      \ifnum#1=1%
         \footnotesize{(cited on page #2)}%
      \else
         \footnotesize{(cited on pages #2)}%
      \fi%
   \fi%
}%

% alias for "(e.g., ...)" citations
\newcommand{\citepeg}[1]{\citep[\eg,][]{#1}}

