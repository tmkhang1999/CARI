        & MID $C_{\text{mat}}$ $\downarrow$
        & MID $\text{Cast}_{\text{RMS}}$ $\downarrow$
        & ARAP $C_{\text{arap}}$ $\downarrow$
        & ARAP $\text{Cast}_{\text{RMS}}$ $\downarrow$ \\
    \midrule
    1 & off & off & 0.250 & 0.287 & 0.108 & 0.060 \\
    2 & on  & off & 0.180 & \textbf{0.268} & \textbf{0.097} & \textbf{0.049} \\
